#!/usr/bin/env node
// orientation CLI — thin wrapper over the installed engine.
// Subcommands:
//   orientation install                  (re)install engine, skill, hooks
//   orientation refresh                  rebuild graphs now (ingest→condense→graph)
//   orientation provenance <cwd> <file>  history/verdict for a file (delete/judge)
//   orientation related    <cwd> <file>  prior work + sibling files (before adding)
//   orientation threads    <cwd>         resume threads (goals rejoined across detours)
//   orientation coupled    <cwd> <file>  files co-edited with this one

const path = require('path');
const { spawnSync } = require('child_process');
const { ACTION_GRAPH: AG } = require('../src/paths');

const NODE = process.execPath;
const [cmd, ...rest] = process.argv.slice(2);

function finish(result) {
  if (result.error) {
    console.error(result.error.message);
    process.exit(1);
  }
  if (result.signal) {
    console.error(`terminated by ${result.signal}`);
    process.exit(1);
  }
  process.exit(result.status == null ? 1 : result.status);
}

function run(file, args) {
  const r = spawnSync(NODE, [path.join(AG, file), ...args], { stdio: 'inherit' });
  finish(r);
}

function runLocal(file, args) {
  const r = spawnSync(NODE, [path.join(__dirname, '..', file), ...args], { stdio: 'inherit' });
  finish(r);
}

switch (cmd) {
  case 'install':
    runLocal('install.js', rest);
    break;
  case 'refresh':
    finish(spawnSync('bash', [path.join(AG, 'refresh.sh')], { stdio: 'inherit' }));
    break;
  case 'provenance':
    run('consume.js', ['--provenance', ...rest]);
    break;
  case 'related':
    run('consume.js', ['--related', ...rest]);
    break;
  case 'threads':
    run('graph.js', ['--threads', ...rest]);
    break;
  case 'coupled':
    run('graph.js', ['--coupled', ...rest]);
    break;
  default:
    console.log(`orientation — reconstruct the real history of code from Claude Code transcripts.

usage:
  orientation install                  install or repair engine, skill, and hooks
  orientation refresh                  rebuild graphs now
  orientation provenance <cwd> <file>  history + verdict (judging/deleting)
  orientation related    <cwd> <file>  prior work + siblings (before adding)
  orientation threads    <cwd>         resume threads across detours
  orientation coupled    <cwd> <file>  files co-edited with this one

The get-oriented skill calls these for you when you're about to judge unfamiliar code.
Engine + hooks install on \`npm install\`; edit ${path.join(AG, 'projects.txt')} to opt projects in.`);
    process.exit(cmd ? 1 : 0);
}
