#!/usr/bin/env node
// orientation CLI. When run from this repo it uses the local src/ engine while
// reading/writing the dogfood state in ~/.eigen/orientation by default.

const path = require('path');
const os = require('os');
const { spawnSync } = require('child_process');

const PKG = path.resolve(__dirname, '..');
const HOME = os.homedir();
const EIGEN = process.env.EIGEN_HOME || path.join(HOME, '.eigen');
const ENGINE = process.env.ORIENTATION_ENGINE_DIR || path.join(PKG, 'src');
const STATE = process.env.ORIENTATION_HOME
  || process.env.EIGEN_ORIENTATION_DIR
  || path.join(EIGEN, 'orientation');
const NODE = process.execPath;
const [cmd, ...rest] = process.argv.slice(2);

function env() {
  return {
    ...process.env,
    ORIENTATION_ENGINE_DIR: ENGINE,
    ORIENTATION_HOME: STATE,
  };
}

function runNode(file, args) {
  const r = spawnSync(NODE, [path.join(ENGINE, file), ...args], {
    stdio: 'inherit',
    env: env(),
  });
  process.exit(r.status || 0);
}

function runScript(command, args) {
  const r = spawnSync(command, args, { stdio: 'inherit', env: env() });
  process.exit(r.status || 0);
}

function runInstaller(args) {
  const r = spawnSync(NODE, [path.join(PKG, 'install.js'), ...args], {
    stdio: 'inherit',
    env: env(),
  });
  process.exit(r.status || 0);
}

switch (cmd) {
  case 'install':
  case 'sync':
    runInstaller(rest);
    break;
  case 'refresh':
    runScript('bash', [path.join(ENGINE, 'refresh.sh'), ...rest]);
    break;
  case 'provenance':
    runNode('consume.js', ['--provenance', ...rest]);
    break;
  case 'related':
    runNode('consume.js', ['--related', ...rest]);
    break;
  case 'query':
    runNode('consume.js', ['--query', ...rest]);
    break;
  case 'sources':
    runNode('consume.js', ['--sources', ...rest]);
    break;
  case 'threads':
    runNode('graph.js', ['--threads', ...rest]);
    break;
  case 'coupled':
    runNode('graph.js', ['--coupled', ...rest]);
    break;
  case 'ingest':
    runNode('ingest.js', rest);
    break;
  case 'doctor':
    runNode('doctor.js', rest);
    break;
  case 'status':
    runNode('status.js', rest);
    break;
  case 'projects':
    runNode('status.js', ['--projects', ...rest]);
    break;
  case 'hooks':
    runNode('hooks.js', rest);
    break;
  default:
    console.log(`orientation - reconstruct real code history from agent transcripts.

usage:
  orientation sync [--all|--codex|--claude|--eigen]  install/sync homes
  orientation refresh                                rebuild indexes
  orientation status [cwd]                           show project index state
  orientation doctor [cwd]                           inspect install/runtime state
  orientation provenance <cwd> <file>                history + verdict
  orientation related    <cwd> <file>                prior goals + siblings
  orientation query      <cwd> <words>               search recorded goals
  orientation sources    <cwd> <goal-id>             show evidence for a goal
  orientation threads    <cwd>                       resume threads
  orientation coupled    <cwd> <file>                co-edited files
  orientation hooks status|install|repair|remove     hook wiring

engine: ${ENGINE}
state:  ${STATE}`);
    process.exit(cmd ? 1 : 0);
}
